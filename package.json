{
  "name": "resumeiq-root",
  "version": "1.0.0",
  "description": "ResumeIQ - AI-powered resume builder and Chrome Extension",
  "scripts": {
    "install:all": "npm install --prefix frontend && cd backend/scripts && npm install && cd ../..",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && .\\venv\\Scripts\\activate && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
